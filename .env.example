# 复制本文件中的变量到「用户/系统环境变量」，或在启动终端里手动 export/set。
# 当前程序不会自动加载 .env；本文件仅作团队统一参考模板。

# ---------------------------------------------------------------------------
# 弱网 / VPN：OKX 读取重试（get_okx_read_retry_config）
# 单次读接口失败时的退避重试；减轻「未返回有效触发价」等间歇性失败。
# ---------------------------------------------------------------------------
QQOKX_READ_RETRY_ATTEMPTS=16
QQOKX_READ_RETRY_BASE_DELAY_SECONDS=1.5
QQOKX_READ_RETRY_MAX_DELAY_SECONDS=24

# 可选：共享数据目录（与 README「数据目录与恢复接管」一致）
# QQOKX_DATA_DIR=D:\qqokx_data
